        <script type="text/javascript">
            function SetSelectedMenu(parentMenuCode, childMenuCode, url) {
                // Call the backend WebMethod to store the selected parent and child menu
                PageMethods.SetSelectedMenu(parentMenuCode, childMenuCode, function () {
                    // After storing the selection, navigate to the provided URL
                    if (url) {
                        window.location.href = url;
                    } else {
                        window.location.reload();  // Reload the page if no URL is provided
                    }
                });
            }
        </script>
    <script type="text/javascript">
        let creditDebitImgThree = document.getElementById("creditDebitImgThree");
        creditDebitImgThree.addEventListener("click", function () {
            let creditDebitImgFour = document.getElementById("creditDebitImgFour");
            creditDebitImgFour.style.display = "flex";
        });
        let creditDebitImgFour = document.getElementById("creditDebitImgFour");
        creditDebitImgFour.addEventListener("mouseleave", function () {
            creditDebitImgFour.style.display = "none";
        });
        let fullBody = document.getElementById("fullbody");
        fullBody.addEventListener("mouseenter", function () {
            let creditDebitImgFour = document.getElementById("creditDebitImgFour");
            creditDebitImgFour.style.display = "none";
        });
        let bellIcon = document.getElementById("bellicon");
        bellIcon.addEventListener("mouseenter", function () {
            let creditDebitImgFour = document.getElementById("creditDebitImgFour");
            creditDebitImgFour.style.display = "none";
        })
    </script>
    <script type="text/javascript">
        let burgerImageSection = document.getElementById("burger-image-section");
        burgerImageSection.addEventListener("click", function () {
            let sidebarToggleBarSection = document.getElementById("sidebar-toggle-bar-section");
            let crossImageSection = document.getElementById("cross-image-section");
            burgerImageSection.style.display = "none";
            sidebarToggleBarSection.style.display = "flex";
            crossImageSection.style.display = "flex";
        });
        let crossImageSection = document.getElementById("cross-image-section");
        crossImageSection.addEventListener("click", function () {
            let sidebarToggleBarSection = document.getElementById("sidebar-toggle-bar-section");
            let crossImageSection = document.getElementById("cross-image-section");
            burgerImageSection.style.display = "flex";
            sidebarToggleBarSection.style.display = "none";
            crossImageSection.style.display = "none";
        })
    </script>
    <script type="text/javascript">
        let colorPallet = document.querySelector(".color-pallet");
        colorPallet.addEventListener("mouseenter", function () {
            let colorPalletBox = document.querySelector(".color-pallet-box");
            let creditDebitImgFour = document.getElementById("creditDebitImgFour");
            creditDebitImgFour.style.display = "none";
            colorPalletBox.style.display = "block";
        });
        let colorPalletOne = document.querySelector(".color-pallet");
        colorPalletOne.addEventListener("mouseleave", function () {
            let colorPalletBox = document.querySelector(".color-pallet-box");
            colorPalletBox.style.display = "none";
        })
        let navBar = document.getElementById("navbar");
        navBar.addEventListener("mouseleave", function () {
            let colorPalletBox = document.querySelector(".color-pallet-box");
            colorPalletBox.style.display = "none";
        });
        const colors = document.getElementsByClassName("colors");

        let i;
        for (i = 0; i < colors.length; i++) {
            colors[i].addEventListener("click", changecolor);
        }
        function changecolor() {
            let color = this.getAttribute("data-color");
            document.documentElement.style.setProperty("--color", color);
        };
    </script>
