            <!-- Parent Menu -->
<asp:Repeater ID="ParentMenuRepeater" runat="server" OnItemDataBound="ParentMenuRepeater_ItemDataBound">
    <ItemTemplate>
        <li class="nav-item">
            <!-- Parent Menu -->
            <a id="lnkParent" runat="server"
               class='nav-link d-flex justify-content-between align-items-center text-white <%# Request.QueryString["selectedParent"] == Eval("ChildMenuCode").ToString() ? "active bg-primary" : "" %>'>
                <span><%# Eval("MenuText") %></span>
                <i class="fas fa-angle-left"></i>
            </a>

            <!-- Child Menu -->
            <asp:PlaceHolder ID="phChildMenu" runat="server" Visible="false">
                <div id="menu_<%# Eval("ChildMenuCode") %>"
                     class="collapse <%# Request.QueryString["selectedParent"] == Eval("ChildMenuCode").ToString() ? "show" : "" %> pl-3">
                    <ul class="nav nav-treeview">
                        <asp:Repeater ID="ChildMenuRepeater" runat="server"
                            DataSource='<%# ((System.Data.DataRowView)Container.DataItem).CreateChildView("ChildRelation") %>'>
                            <ItemTemplate>
                                <li class="nav-item">
                                    <a href='<%# Eval("NavigateURL") + "?selectedParent=" + Eval("ParentMenuCode") + "&selectedChild=" + Eval("ChildMenuCode") %>'
                                       class='nav-link <%# Request.QueryString["selectedChild"] == Eval("ChildMenuCode").ToString() ? "active bg-white text-dark font-weight-bold" : "text-white-50" %>'>
                                        <%# Eval("MenuText") %>
                                    </a>
                                </li>
                            </ItemTemplate>
                        </asp:Repeater>
                    </ul>
                </div>
            </asp:PlaceHolder>
        </li>
    </ItemTemplate>
</asp:Repeater>








        </ul>
    </nav>

    
</aside>
            
            


