        <Style>
        .pagination-container {
    text-align: center;
}

.pagination-container table {
    width: auto !important;
    margin: 0 auto;
}

.pagination-container td {
    padding: 0.5rem;
}

/* Optional: Style the pager links to look like Bootstrap buttons */
.pagination-container a, .pagination-container span {
    margin: 0 3px;
    padding: 0.25rem 0.6rem;
    border: 1px solid #007bff;
    color: #007bff;
    border-radius: 0.2rem;
    text-decoration: none;
    font-size: 0.875rem;
}

.pagination-container span {
    background-color: #007bff;
    color: white;
}
    </Style>

<style>
/* Outer spinning circle */
.spinner-circle {
  width: 7rem;
  height: 7rem;
  border: 8px solid #dee2e6; /* Bootstrap gray-300 */
  border-top: 8px solid #0d6efd; /* Bootstrap primary */
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* Rotate animation */
@keyframes spin {
  100% {
    transform: rotate(360deg);
  }
}

/* Inner pulsing icon */
.ping-icon {
  color: #0d6efd; /* Bootstrap primary blue */
  animation: ping 1.5s infinite;
}

/* Pulse animation */
@keyframes ping {
  0% {
    transform: scale(1);
    opacity: 1;
  }
  75% {
    transform: scale(1.5);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 0;
  }
}
</style>  
    
