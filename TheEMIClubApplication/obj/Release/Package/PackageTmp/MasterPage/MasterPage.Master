    <style type="text/css">
        .dropdown-toggle{
            border: 3px solid brown;
            position: relative;
        }
        .dropdownmenubar{
            position: relative; 
            top: 150px;
            height: 40vh;
            overflow: auto;
        }
        .dropdown-item{
            border-bottom: 1px solid grey;
        }
        .dropdown-item span{
            color: var(--color);
            font-size: 13px;
            font-weight: bold;
        }
        .notificationmessages{
            font-size: 12px;
            color: black;
            font-weight: 500;
        }
    </style>
      <style>
    .dropdown-menu {
        width: 310px; /* Adjust the width */
        max-height: 400px; /* Adjust height for scroll */
        overflow-y: auto; /* Add scrolling for overflow */
    }

    .media {
        display: flex;
        align-items: center;
        padding: 10px 15px;
    }

    .media-body {
        padding-left: 10px;
    }

    .dropdown-item-title {
        font-size: 11px;
        font-weight: 600;
        color: #333;
    }

    .dropdown-item-title .fas {
        font-size: 12px;
        color: #f39c12; /* Star color */
    }

    .text-sm {
        font-size: 11px;
        line-height: 1.4;
    }

    .text-muted {
        font-size: 9px;
        color: #6c757d;
    }

    .dropdown-divider {
        margin: 2px 0;
        background-color: #e9ecef;
    }

    .dropdown-footer {
        text-align: center;
        font-size: 14px;
        color: #007bff;
        cursor: pointer;
        padding: 10px;
    }

        .notification-item:hover {
    background-color: #f0f8ff; /* Light blue background on hover */
    transition: background-color 0.3s ease;
}

    .dropdown-footer:hover {
        background-color: #f1f1f1;
    }

    .followup-remarks {
    word-wrap: break-word;  /* Breaks words if they are too long */
    white-space: normal;    /* Ensures the text wraps to the next line */
    max-width: 250px;       /* Adjust the width as needed */
    overflow: hidden;       /* Ensures that any extra text does not overflow */
}

    .badge-danger {
        background-color: #e74c3c;
        position: absolute;
        top: 5px;
        right: 5px;
        font-size: 12px;
        padding: 5px;
        border-radius: 50%;
    }

    .navbar-badge {
        position: relative;
    }

    .img-size-50 {
        width: 50px;
        height: 50px;
    }

    .img-circle {
        border-radius: 50%;
    }

   
</style>

    <style>
        .main-sidebar {
    display: flex;
    flex-direction: column;
    height: 100vh; /* full viewport height */
}

.sidebar-nav {
    flex: 1 1 auto;  /* take remaining space */
    overflow-y: auto; /* vertical scroll */
    overflow-x: hidden; /* prevent horizontal scroll */
}
    </style>


